    "./dist/style/style.js": "./dist/style/style.js",
    "./dist/style/style": "./dist/style/style.js",
    "./dist/style/style.css": "./dist/style/style.css",
    "./dist/style/index.js": "./dist/style/index.js",
    "./dist/style/index": "./dist/style/index.js",
    "./dist/style": "./dist/style/index.js"
  },
  "keywords": [
    "ezuikit",
    "aichat",
